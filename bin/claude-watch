#!/usr/bin/env node

import { randomUUID } from "node:crypto";
import { spawn } from "node:child_process";

const WATCHER_URL = process.env.CLAUDE_WATCHER_URL ?? "http://localhost:4242";

const args = process.argv.slice(2);
const separatorIndex = args.indexOf("--");
if (separatorIndex === -1) {
  console.error("Usage: claude-watch --title \"Task title\" -- <command> [args]");
  process.exit(1);
}

const labelArgs = args.slice(0, separatorIndex);
const commandArgs = args.slice(separatorIndex + 1);
if (commandArgs.length === 0) {
  console.error("Missing command after --");
  process.exit(1);
}

const title = parseTitle(labelArgs);
const sessionId = randomUUID();

await postEvent({
  type: "task-start",
  sessionId,
  title,
  cwd: process.cwd(),
  status: "running",
  notes: "Wrapper started command"
});

const child = spawn(commandArgs[0], commandArgs.slice(1), {
  stdio: "inherit",
  shell: false
});

child.on("spawn", () => {
  void postEvent({
    type: "task-update",
    sessionId,
    pid: child.pid,
    status: "running",
    notes: "Command spawned"
  });
});

child.on("exit", async (code, signal) => {
  await postEvent({
    type: "task-end",
    sessionId,
    pid: child.pid,
    status: code === 0 ? "completed" : "error",
    notes: signal ? `terminated by ${signal}` : `exit code ${code}`
  });

  if (signal) {
    process.kill(process.pid, signal);
  }
  process.exit(code ?? 1);
});

async function postEvent(payload) {
  const body = JSON.stringify({ ...payload, at: new Date().toISOString() });

  try {
    await fetch(`${WATCHER_URL}/api/events`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body
    });
  } catch (error) {
    console.error(`Watcher event delivery failed: ${error.message}`);
  }
}

function parseTitle(values) {
  const titleIndex = values.indexOf("--title");
  if (titleIndex === -1 || !values[titleIndex + 1]) {
    return "Claude task";
  }
  return values[titleIndex + 1];
}
