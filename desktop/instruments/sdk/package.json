{
  "name": "@tango/instrument-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "tango-sdk": "./src/cli/index.ts"
  },
  "scripts": {
    "sync": "bun run src/cli/index.ts sync"
  },
