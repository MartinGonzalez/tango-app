{
  "name": "@tango/instrument-tasks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build:frontend": "bun build src/index.tsx --outfile dist/index.js --format esm --target browser",
    "build:backend": "bun build src/backend.ts --outfile dist/backend.js --format esm --target bun",
    "build": "bun run build:frontend && bun run build:backend",
    "check:portable": "bun run build && bun run scripts/verify-portable.mjs",
    "build:external-local": "bun run build && bun run scripts/build-external-local.mjs",
    "test": "bun test ./test"
  },
  "dependencies": {
    "@tango/api": "file:../api"
  },
  "tango": {
    "instrument": {
      "id": "tasks",
      "name": "Tasks",
      "group": "Core",
      "runtime": "react",
      "entrypoint": "./dist/index.js",
      "backendEntrypoint": "./dist/backend.js",
      "hostApiVersion": "2.0.0",
      "launcher": {
        "sidebarShortcut": {
          "enabled": true,
          "label": "Tasks",
          "icon": "task",
          "order": 20
        }
      },
      "panels": {
        "sidebar": true,
        "first": true,
        "second": false,
        "right": false
      },
      "permissions": [
        "storage.files",
        "storage.db",
        "storage.properties",
        "sessions",
        "connectors.read",
        "connectors.credentials.read",
        "connectors.connect",
        "stages.read",
        "stages.observe"
      ]
    }
  }
}
