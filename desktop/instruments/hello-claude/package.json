{
  "name": "@tango/instrument-hello-claude",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.tsx --outfile dist/index.js --format esm --target browser"
  },
  "dependencies": {
    "@tango/api": "file:../api"
  },
  "tango": {
    "instrument": {
      "id": "hello-claude",
      "name": "Hello Claude",
      "group": "Examples",
      "runtime": "react",
      "entrypoint": "./dist/index.js",
      "hostApiVersion": "2.0.0",
      "launcher": {
        "sidebarShortcut": {
          "enabled": true,
          "label": "Hello",
          "icon": "chat",
          "order": 90
        }
      },
      "panels": {
        "sidebar": true,
        "first": true,
        "second": false,
        "right": false
      },
      "permissions": [
        "storage.properties",
        "sessions",
        "stages.read"
      ]
    }
  }
}
