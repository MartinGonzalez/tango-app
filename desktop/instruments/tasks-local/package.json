{
  "name": "@tango/instrument-tasks-local",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "tango": {
    "instrument": {
      "id": "tasks-local",
      "name": "Tasks Local",
      "group": "Local",
      "entrypoint": "./dist/index.js",
      "backendEntrypoint": "./dist/backend.js",
      "hostApiVersion": "1.0.0",
      "launcher": {
        "sidebarShortcut": {
          "enabled": true,
          "label": "Tasks Local",
          "icon": "task",
          "order": 21
        }
      },
      "panels": {
        "sidebar": true,
        "first": false,
        "second": true,
        "right": false
      },
      "permissions": [
        "storage.files",
        "storage.db",
        "storage.properties",
        "sessions",
        "connectors.read",
        "connectors.credentials.read",
        "connectors.connect",
        "stages.read",
        "stages.observe"
      ]
    }
  }
}
