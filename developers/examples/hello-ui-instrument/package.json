{
  "name": "@example/tango-instrument-hello-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --format esm --target browser"
  },
  "dependencies": {
    "@tango/instrument-sdk": "file:../../../desktop/instruments/sdk",
    "@tango/instrument-ui": "file:../../../desktop/instruments/ui"
  },
  "tango": {
    "instrument": {
      "id": "hello-ui",
      "name": "Hello UI",
      "group": "Examples",
      "runtime": "vanilla",
      "entrypoint": "./dist/index.js",
      "backendEntrypoint": "./dist/backend.js",
      "hostApiVersion": "2.0.0",
      "launcher": {
        "sidebarShortcut": {
          "enabled": true,
          "label": "Hello UI",
          "icon": "plugins",
          "order": 50
        }
      },
      "panels": {
        "sidebar": true,
        "first": false,
        "second": true,
        "right": false
      },
      "permissions": [
        "sessions",
        "stages.read",
        "stages.observe"
      ]
    }
  }
}
